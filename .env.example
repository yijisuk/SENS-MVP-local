# ─────────────────────────────────────────────────────────────────────────────
# SENS-MVP-local — Environment Variables
# Copy this file to .env and fill in your values before running the bot!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Telegram ───
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Supabase ───
# Found in your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-secret-key

# ─── Perplexity AI ───
# Obtain from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-perplexity-api-key

# ─── OpenRouter ───
# Obtain from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# ─── Manus AI ───
# Obtain from your Manus account dashboard
MANUS_API_KEY=your-manus-api-key

# ─── FRED (Federal Reserve Economic Data) ───
# Obtain from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# ─── Financial Modeling Prep (FMP) ───
# Obtain from https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your-fmp-api-key

# ─── ScrapeGraphAI ───
# Obtain from https://scrapegraphai.com
SCRAPEGRAPH_API_KEY=your-scrapegraph-api-key
